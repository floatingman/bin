#!/bin/bash
# Full theme switcher with light/dark mode support

set -e

KITTY_LIGHT_DIR="$HOME/.config/kitty/daylight-themes"
KITTY_DARK_DIR="$HOME/.config/kitty/dark-themes"
KITTY_CURRENT="$HOME/.config/kitty/current-theme.conf"

WEZTERM_LIGHT_DIR="$HOME/.config/wezterm/daylight-themes"
WEZTERM_DARK_DIR="$HOME/.config/wezterm/dark-themes"
WEZTERM_CURRENT="$HOME/.config/wezterm/current-theme.lua"

I3_CONFIG="$HOME/.config/i3/config"
I3_LIGHT_DIR="$HOME/.config/i3/themes"
I3_DARK_DIR="$HOME/.config/i3/dark-themes"

show_usage() {
    cat << EOF
Theme Switcher - Light/Dark Modes

Usage: theme <theme-name> [light|dark]

Themes:
  github     - GitHub (winner of daylight testing)
  gruvbox    - Gruvbox (warm colors)
  nord       - Nord (cool, desaturated)

Modes:
  light      - Light background (default)
  dark       - Dark background

Examples:
  theme github light    # GitHub Light Dim (best for outdoors)
  theme github dark     # GitHub Dark
  theme gruvbox         # Defaults to light

Apps affected: kitty, wezterm, i3

Reload:
  kitty:   Ctrl+Shift+F5
  wezterm: Ctrl+Shift+R
  i3:      Mod4+Shift+R
EOF
}

if [ -z "$1" ]; then
    show_usage
    exit 1
fi

THEME="$1"
MODE="${2:-light}"

case "$THEME" in
    github)
        case "$MODE" in
            light)
                KITTY_FILE="$KITTY_LIGHT_DIR/github-light-dim.conf"
                WEZTERM_FILE="$WEZTERM_LIGHT_DIR/github-light-dim.lua"
                I3_FILE="$I3_LIGHT_DIR/github-light-dim"
                THEME_NAME="GitHub Light Dim"
                ;;
            dark)
                KITTY_FILE="$KITTY_DARK_DIR/github-dark.conf"
                WEZTERM_FILE="$WEZTERM_DARK_DIR/github-dark.lua"
                I3_FILE="$I3_DARK_DIR/github-dark"
                THEME_NAME="GitHub Dark"
                ;;
            *)
                echo "✗ Unknown mode: $MODE"
                show_usage
                exit 1
                ;;
        esac
        ;;
    gruvbox)
        case "$MODE" in
            light)
                KITTY_FILE="$KITTY_LIGHT_DIR/gruvbox-light.conf"
                WEZTERM_FILE="$WEZTERM_LIGHT_DIR/gruvbox-light.lua"
                I3_FILE="$I3_LIGHT_DIR/gruvbox-light"
                THEME_NAME="Gruvbox Light"
                ;;
            dark)
                KITTY_FILE="$KITTY_DARK_DIR/gruvbox-dark.conf"
                WEZTERM_FILE="$WEZTERM_DARK_DIR/gruvbox-dark.lua"
                I3_FILE="$I3_DARK_DIR/gruvbox-dark"
                THEME_NAME="Gruvbox Dark"
                ;;
            *)
                echo "✗ Unknown mode: $MODE"
                show_usage
                exit 1
                ;;
        esac
        ;;
    nord)
        case "$MODE" in
            light)
                KITTY_FILE="$KITTY_LIGHT_DIR/nord-light.conf"
                WEZTERM_FILE="$WEZTERM_LIGHT_DIR/nord-light.lua"
                I3_FILE="$I3_LIGHT_DIR/nord-light"
                THEME_NAME="Nord Light"
                ;;
            dark)
                KITTY_FILE="$KITTY_DARK_DIR/nord-dark.conf"
                WEZTERM_FILE="$WEZTERM_DARK_DIR/nord-dark.lua"
                I3_FILE="$I3_DARK_DIR/nord-dark"
                THEME_NAME="Nord Dark"
                ;;
            *)
                echo "✗ Unknown mode: $MODE"
                show_usage
                exit 1
                ;;
        esac
        ;;
    *)
        echo "✗ Unknown theme: $THEME"
        show_usage
        exit 1
        ;;
esac

# Verify files exist
for file in "$KITTY_FILE" "$WEZTERM_FILE" "$I3_FILE"; do
    if [ ! -f "$file" ]; then
        echo "✗ Theme file not found: $file"
        exit 1
    fi
done

# Update kitty
rm -f "$KITTY_CURRENT"
ln -s "$KITTY_FILE" "$KITTY_CURRENT"

# Update wezterm
rm -f "$WEZTERM_CURRENT"
ln -s "$WEZTERM_FILE" "$WEZTERM_CURRENT"

# Update i3
sed -i "s|^include .*/\.config/i3/themes/.*|include $I3_FILE|" "$I3_CONFIG"
sed -i "s|^include .*/\.config/i3/dark-themes/.*|include $I3_FILE|" "$I3_CONFIG"

# Reload i3
i3-msg reload 2>/dev/null || echo "⚠ i3 reload failed"

# Update i3status colors
source ~/.local/bin/theme-switch-status
update_i3status_colors "$THEME" "$MODE"

# Update GTK theme
update_gtk_theme() {
    local gtk_theme
    local prefer_dark

    if [ "$MODE" = "light" ]; then
        gtk_theme="adw-gtk3"
        prefer_dark="false"
    else
        gtk_theme="adw-gtk3-dark"
        prefer_dark="true"
    fi

    local gtk_settings="$HOME/.config/gtk-3.0/settings.ini"
    if [ -f "$gtk_settings" ]; then
        sed -i "s/^gtk-theme-name=.*/gtk-theme-name=$gtk_theme/" "$gtk_settings"
        sed -i "s/^gtk-application-prefer-dark-theme=.*/gtk-application-prefer-dark-theme=$prefer_dark/" "$gtk_settings"
    fi

    # Update gsettings for GNOME apps
    if command -v gsettings >/dev/null 2>&1; then
        local color_scheme
        if [ "$MODE" = "light" ]; then
            color_scheme="default"
        else
            color_scheme="prefer-dark"
        fi
        gsettings set org.gnome.desktop.interface gtk-theme "$gtk_theme" 2>/dev/null || true
        gsettings set org.gnome.desktop.interface color-scheme "$color_scheme" 2>/dev/null || true
    fi
}

update_gtk_theme

echo "✓ Switched to $THEME_NAME"
echo ""
echo "Reload apps:"
echo "  kitty:   Ctrl+Shift+F5"
echo "  wezterm: Ctrl+Shift+R"
echo "  i3:      Mod4+Shift+R"
